# Port Configuration
# IMPORTANT: These ports must stay in sync with backend .env values:
# - VITE_PORT must match backend FRONTEND_PORT (for local dev CORS/CSRF)
# - VITE_API_URL must point to backend API (use Cloudflare tunnel URL in production, e.g., https://pp-api.dcorps.dev/api)
VITE_PORT=3330
VITE_API_URL=https://pp-api.dcorps.dev/api
